# Normalize line endings to LF in the repo (avoids CRLF churn on Windows).
* text=auto eol=lf

*.ipynb  text eol=lf
*.py     text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf

# Binary artifacts — never normalize.
*.docx     binary
*.joblib   binary
*.pt       binary
*.pth      binary
*.parquet  binary
*.png      binary
*.jpg      binary
