# --- Raw downloads: reproducible from public sources, never committed ---
/data/raw/*
!/data/raw/.gitkeep

# --- Interim generated artifacts (candidates, temp) ---
/data/interim/*
!/data/interim/.gitkeep

# --- Models ---
# Large/regenerable binaries stay out (baseline RF/calibrated, etc.); the small
# DEPLOYED hybrid models ARE committed so the repo + HF demo run on clone.
/models/*
!/models/.gitkeep
!/models/activity_clf_esm.joblib
!/models/tox_clf_esm.joblib
!/models/mic_reg.joblib
!/models/generator_vae.pt
!/models/esm_config.json
!/models/metrics_esm.json

# Keep processed datasets + manifests tracked (small, aids reproducibility):
# data/processed/*.parquet and data/processed/manifest.json ARE committed.

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/

# --- Gradio demo runtime ---
.gradio/
flagged/

# --- scratch run logs ---
reports/_*.log

# --- OS / editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*~
