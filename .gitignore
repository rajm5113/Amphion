# --- Raw downloads: reproducible from public sources, never committed ---
/data/raw/*
!/data/raw/.gitkeep

# --- Interim generated artifacts (candidates, temp) ---
/data/interim/*
!/data/interim/.gitkeep

# --- Large model binaries (kept reproducible via code; cards are committed) ---
/models/*
!/models/.gitkeep

# Keep processed datasets + manifests tracked (small, aids reproducibility):
# data/processed/*.parquet and data/processed/manifest.json ARE committed.

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/

# --- Gradio demo runtime ---
.gradio/
flagged/

# --- OS / editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*~
